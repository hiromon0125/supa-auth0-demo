# Copy these values into .env and replace them with your real credentials
NUXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NUXT_PUBLIC_AUTH0_CLIENT_ID=your_auth0_client_id
NUXT_PUBLIC_AUTH0_AUDIENCE=your_auth0_api_identifier
NUXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3000
NUXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
